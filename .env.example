# Copy to .env and adjust as needed. Values here are used by docker-compose.

# Postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=task_manager
POSTGRES_PORT=5433

# Backend
BACKEND_PORT=5000
JWT_SECRET=replace_with_a_strong_secret
FRONTEND_URL=http://localhost:3000

# Frontend (baked at build time into the Vite bundle)
FRONTEND_PORT=3000
VITE_API_URL=http://localhost:5000/api

# Google OAuth (optional — set both to enable Google sign-in)
GOOGLE_CLIENT_ID=
VITE_GOOGLE_CLIENT_ID=
